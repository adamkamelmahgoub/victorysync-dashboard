# VictorySync environment template
# Copy to local .env files or configure in Vercel/Supabase. Do not commit real values.

NODE_ENV=production
PORT=4000
APP_PORT=4000

# Frontend
VITE_API_BASE_URL=https://api.example.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace-with-clerk-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
VITE_DEV_ADMIN_ID=

# Server-side Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
DATABASE_URL=postgresql://user:password@db-pooler-host:6543/postgres

# Clerk auth
CLERK_SECRET_KEY=sk_test_replace-with-clerk-secret-key

# API hardening
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token
CSRF_SECRET=replace-with-random-32-byte-secret
INVITE_CODE_SECRET=replace-with-random-32-byte-secret

# MightyCall
MIGHTYCALL_API_BASE_URL=https://ccapi.mightycall.com/v4
MIGHTYCALL_BASE_URL=https://ccapi.mightycall.com/v4
MIGHTYCALL_API_KEY=replace-with-mightycall-api-key
MIGHTYCALL_USER_KEY=replace-with-mightycall-user-key

# Stripe billing
STRIPE_SECRET_KEY=sk_live_or_test_replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-signing-secret
STRIPE_APP_URL=https://dashboard.victorysync.com
# Optional fallback if a billing plan does not yet have stripe_price_id stored.
STRIPE_DEFAULT_PRICE_ID=price_replace-with-default-price-id
# Optional named fallbacks. Example: a plan named "Professional Plan" maps to STRIPE_PRICE_PROFESSIONAL_PLAN.
STRIPE_PRICE_PROFESSIONAL_PLAN=price_replace-with-professional-price-id

# Internal service calls
SERVICE_KEY=replace-with-random-internal-service-key
SERVER_SERVICE_KEY=replace-with-random-internal-service-key
SERVICE_SECRET=replace-with-random-internal-service-key

# McGraw Now lead intake
MCGRAWNOW_WEBHOOK_SECRET=replace-with-random-32-char-secret
VICTORYSYNC_DEFAULT_ORG_ID=replace-with-default-org-uuid

# Feature flags
ENABLE_SMS=true
ENABLE_RECORDINGS=true
ENABLE_BILLING=true
ENABLE_ADMIN_FEATURES=true
